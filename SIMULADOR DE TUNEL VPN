//  ALGORITMO 1: CIFRADO CESAR
class CifradoCesar {
public:
    static string cifrar(const string& texto, int clave) {
        string resultado = texto;
        for (char& c : resultado) {
            if (isalpha(c)) {
                char base = isupper(c) ? 'A' : 'a';
                c = (char)((c - base + clave) % 26 + base);
            }
        }
        return resultado;
    }

    static string descifrar(const string& texto, int clave) {
        return cifrar(texto, 26 - (clave % 26));
    }

    static void mostrarProceso(const string& texto, int clave) {
        cout << "\n  Tabla de sustitución (primeros 10 chars):\n";
        cout << "  " << string(40, '-') << "\n";
        cout << "  Original  ->  Cifrado  (desplazamiento: " << clave << ")\n";
        cout << "  " << string(40, '-') << "\n";
        int count = 0;
        for (char c : texto) {
            if (count >= 10) break;
            if (isalpha(c)) {
                char base = isupper(c) ? 'A' : 'a';
                char cifrado = (char)((c - base + clave) % 26 + base);
                cout << "     '" << c << "'  (" << (int)c << ")  ->  '"
                    << cifrado << "'  (" << (int)cifrado << ")\n";
                count++;
            }
        }
    }
};

//  ALGORITMO 2: CIFRADO XOR (simula cifrado simetrico AES-like)
class CifradoXOR {
public:
    static string cifrar(const string& texto, const string& clave) {
        string resultado = texto;
        for (size_t i = 0; i < texto.size(); i++) {
            resultado[i] = texto[i] ^ clave[i % clave.size()];
        }
        return resultado;
    }

    // Devuelve representacion hexadecimal
    static string aHex(const string& datos) {
        ostringstream oss;
        for (unsigned char c : datos) {
            oss << hex << setw(2) << setfill('0') << (int)c << " ";
        }
        return oss.str();
    }

    static string desdeHex(const string& hex_str) {
        return hex_str; // simplificado para demo
    }
};

//  ALGORITMO 3: HASH SIMPLE (simula SHA-256)
class HashSimple {
public:
    // Hash polinomial
    static uint64_t calcular(const string& texto) {
        uint64_t hash = 0xcbf29ce484222325ULL; // FNV offset basis
        for (unsigned char c : texto) {
            hash ^= c;
            hash *= 0x100000001b3ULL;           // FNV prime
        }
        return hash;
    }

    static string aString(uint64_t hash) {
        ostringstream oss;
        oss << hex << uppercase << setw(16) << setfill('0') << hash;
        return oss.str();
    }
};

//  SIMULADOR DE TUNEL VPN COMPLETO
class TunelVPN {
