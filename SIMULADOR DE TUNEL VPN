        mostrarEncabezado();

        // ── PASO 1: Mensaje original ─────────────────────────
        paso(1, "MENSAJE ORIGINAL (texto plano)");
        mostrarCampos("Remitente (Cliente):", ip_cliente, GREEN);
        mostrarCampos("Destino (Servidor):", ip_servidor, BLUE);
        mostrarCampos("Mensaje:", mensaje, WHITE);
        mostrarCampos("Estado:", "SIN CIFRAR - VULNERABLE", RED);

        cout << "\n  " << RED << " Sin VPN: cualquier nodo intermedio puede leer esto." << RESET << "\n";
        pausa();

        // ── PASO 2: Generacion de claves ─────────────────────
        paso(2, "HANDSHAKE VPN - Intercambio de Claves");
        cout << "  Simulando intercambio seguro de claves:\n\n";
        mostrarCampos("Clave Cesar (ROT):", to_string(clave_cesar), YELLOW);
        mostrarCampos("Clave XOR:", clave_xor, YELLOW);
        mostrarCampos("Hash de verificación:", "", YELLOW);
        uint64_t hash_original = HashSimple::calcular(mensaje);
        string   hash_str = HashSimple::aString(hash_original);
        cout << "  " << BOLD << setw(22) << left << "" << RESET
            << YELLOW << hash_str << RESET << "\n";
        cout << "\n  " << GREEN << "  Claves intercambiadas de forma segura." << RESET << "\n";
        pausa();

        // ── PASO 3: Primera capa - Cesar ─────────────────────
        paso(3, "CAPA 1 - Cifrado Cesar (ROT-13)");
        string cifrado_cesar = CifradoCesar::cifrar(mensaje, clave_cesar);
        CifradoCesar::mostrarProceso(mensaje, clave_cesar);
        cout << "\n";
        mostrarCampos("Entrada:", mensaje, WHITE);
        mostrarCampos("Salida cifrada:", cifrado_cesar, CYAN);
        pausa();

        // ── PASO 4: Segunda capa - XOR ───────────────────────
        paso(4, "CAPA 2 - Cifrado XOR ");
        string cifrado_xor = CifradoXOR::cifrar(cifrado_cesar, clave_xor);
        string cifrado_xor_hex = CifradoXOR::aHex(cifrado_xor);
        mostrarCampos("Entrada:", cifrado_cesar, CYAN);
        mostrarCampos("Clave sesion:", clave_xor, YELLOW);
        mostrarCampos("Salida (hex):", cifrado_xor_hex, MAGENTA);
        cout << "\n  " << GREEN << " Mensaje completamente ilegible en tránsito." << RESET << "\n";
        pausa();

        // ── PASO 5: Empaquetado VPN ──────────────────────────
        paso(5, "ENCAPSULACION - Paquete VPN");
        cout << "  ┌─────────────────────────────────────────┐\n";
        cout << "  │  ENCABEZADO VPN                           │\n";
        cout << "  │  Src: " << GREEN << ip_cliente << RESET
            << "  ->  Dst: " << BLUE << ip_servidor << RESET << "       │\n";
        cout << "  ├─────────────────────────────────────────┤\n";
        cout << "  │  PAYLOAD CIFRADO (XOR + Cesar)          │\n";
        cout << "  │  " << MAGENTA << cifrado_xor_hex.substr(0, 35) << "...│\n" << RESET;
        cout << "  ├─────────────────────────────────────────┤\n";
        cout << "  │  HASH: " << YELLOW << hash_str.substr(0, 16) << "...     │\n" << RESET;
        cout << "  └─────────────────────────────────────────┘\n";
        pausa();

        // ── PASO 6: Transmision ──────────────────────────────
        paso(6, "TRANSMISION POR INTERNET (Tunel cifrado)");
        cout << "\n";
        cout << "  " << GREEN << ip_cliente << RESET
            << "  ══[TUNEL VPN CIFRADO]══>  "
            << BLUE << ip_servidor << RESET << "\n\n";
        cout << "  Nodos intermedios ven solo:\n";
        cout << "  " << MAGENTA << cifrado_xor_hex.substr(0, 48) << "\n" << RESET;
        cout << "\n  " << GREEN << " Hacker intercepta... pero no puede descifrar." << RESET << "\n";
        pausa();

        // ── PASO 7: Descifrado en servidor ───────────────────
        paso(7, "DESCIFRADO EN EL SERVIDOR");
        string desc_xor = CifradoXOR::cifrar(cifrado_xor, clave_xor); // XOR es simétrico
        string desc_cesar = CifradoCesar::descifrar(desc_xor, clave_cesar);

        mostrarCampos("Paquete recibido (hex):", cifrado_xor_hex.substr(0, 30) + "...", MAGENTA);
        mostrarCampos("Tras descifrar XOR:", desc_xor, CYAN);
        mostrarCampos("Tras descifrar Cesar:", desc_cesar, GREEN);
        pausa();

        // ── PASO 8: Verificacion de integridad ───────────────
        paso(8, "VERIFICACION DE INTEGRIDAD (Hash)");
        uint64_t hash_recibido = HashSimple::calcular(desc_cesar);
        bool     ok = (hash_recibido == hash_original);

        mostrarCampos("Hash original:", hash_str, YELLOW);
        mostrarCampos("Hash recalculado:", HashSimple::aString(hash_recibido),
            ok ? GREEN : RED);

        if (ok) {
            cout << "\n  " << BOLD << GREEN
                << "  MENSAJE INTEGRO - No fue modificado en tránsito." << RESET << "\n";
        }
        else {
            cout << "\n  " << BOLD << RED
                << " ALERTA: El mensaje fue alterado!" << RESET << "\n";
        }
        pausa();

        // ── RESUMEN ──────────────────────────────────────────
        titulo("RESUMEN DEL TUNEL VPN");
        mostrarCampos("Mensaje original:", mensaje, WHITE);
        mostrarCampos("Mensaje cifrado (hex):", cifrado_xor_hex.substr(0, 25) + "...", MAGENTA);
        mostrarCampos("Mensaje descifrado:", desc_cesar, GREEN);
        mostrarCampos("Integridad:", ok ? "VERIFICADA " : "FALLIDA ✘", ok ? GREEN : RED);
        mostrarCampos("Protocolo capa 1:", "Cifrado Cesar (ROT-" + to_string(clave_cesar) + ")", CYAN);
        mostrarCampos("Protocolo capa 2:", "Cifrado XOR (sesion)", CYAN);
        mostrarCampos("Integridad:", "Hash FNV-64", CYAN);
        cout << "\n";
        linea();
    }
};

